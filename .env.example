NODE_ENV=development
PORT=5000

# MongoDB — replace with your Atlas connection string
MONGODB_URI=mongodb://localhost:27017/craftopia

# JWT — use a long random secret in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS — frontend origin (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3002,https://craftopia-arts.netlify.app

# Cloudinary Configuration (get these from cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
